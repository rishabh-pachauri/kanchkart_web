# App
NEXT_PUBLIC_APP_URL=https://www.kanchkart.com
NEXT_PUBLIC_BRAND_NAME=KanchKart
NEXTAUTH_URL=https://www.kanchkart.com
AUTH_SECRET=replace-with-a-32-byte-secret

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/kanchkart?schema=public
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/kanchkart?schema=public

# Auth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Admin bootstrap
ADMIN_EMAIL=founder@kanchkart.com
ADMIN_PASSWORD=change-this-before-seeding

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=kanchkart

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Email
RESEND_API_KEY=
EMAIL_FROM=KanchKart <orders@kanchkart.com>
ADMIN_NOTIFICATION_EMAIL=orders@kanchkart.com

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

